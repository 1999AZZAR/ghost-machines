# Ghost Machines - Architecture Parameters

# [Required for Remote Mode]
# Your Cloudflare Tunnel Token
TUNNEL_TOKEN=

# [Optional] Port Overrides
G1_PORT=2223
G2_PORT=2224

# [Optional] Custom Names
G1_NAME=ghost-machine1
G2_NAME=ghost-machine2

# [Optional] Resource Overrides (Values like 1.0, 8G, etc.)
# Note: These are automatically managed by start.sh unless set here.
G1_CPU=
G1_MEM=
G2_CPU=
G2_MEM=
